# =====================================================
# GuinéaManager ERP - Configuration Environment
# =====================================================

# Server
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# Database - Supabase PostgreSQL
DATABASE_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres"

# Redis - Upstash
REDIS_URL="redis://default:xxxxx@xxxxx.upstash.io:6379"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Africa's Talking - SMS
AFRICASTALKING_API_KEY=your-africas-talking-api-key
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=GuineaManager
# Format: +224 XXX XXX XXX for Guinée

# Orange Money Guinée - Sandbox
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/gn/v1
ORANGE_MONEY_CLIENT_ID=your-orange-money-client-id
ORANGE_MONEY_CLIENT_SECRET=your-orange-money-client-secret
ORANGE_MONEY_MERCHANT_CODE=your-merchant-code
ORANGE_MONEY_WEBHOOK_SECRET=your-webhook-secret

# Resend - Email
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@guineamanager.com

# Supabase Storage
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Application
APP_NAME=GuinéaManager
APP_URL=https://app.guineamanager.com
SUPPORT_EMAIL=support@guineamanager.com
SUPPORT_PHONE=+224 XXX XXX XXX

# Plan Limits
PLAN_FREE_MAX_INVOICES=50
PLAN_FREE_MAX_USERS=1
PLAN_STANDARD_MAX_USERS=5
PLAN_STANDARD_MAX_INVOICES=-1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRES_IN_MINUTES=5

# Security
BCRYPT_SALT_ROUNDS=12
