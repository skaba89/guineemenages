# =============================================================================
# GuinéaManager ERP - Configuration Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=production
PORT=3000

# Frontend API URL - Use relative URL to leverage Next.js API proxy
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_APP_URL=https://guineamanager.com

# Backend URL (for API proxy - server side only)
BACKEND_URL=http://localhost:3001

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="file:./dev.db"
# For PostgreSQL in production:
# DATABASE_URL="postgresql://user:password@localhost:5432/guineamanager"

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Session
SESSION_SECRET=your-session-secret-change-this

# =============================================================================
# EMAIL CONFIGURATION (SMTP)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Alternative: SendGrid
# SENDGRID_API_KEY=your-sendgrid-api-key

# =============================================================================
# TWO-FACTOR AUTHENTICATION (2FA)
# =============================================================================
# For SMS 2FA - Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+224XXXXXXXX

# =============================================================================
# MOBILE MONEY - ORANGE MONEY
# =============================================================================
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/dev/v1
ORANGE_MONEY_CLIENT_ID=your-orange-money-client-id
ORANGE_MONEY_CLIENT_SECRET=your-orange-money-client-secret

# =============================================================================
# MOBILE MONEY - MTN MONEY
# =============================================================================
MTN_MONEY_API_URL=https://proxy.momoapi.mtn.com
MTN_MONEY_SUBSCRIPTION_KEY=your-mtn-subscription-key
MTN_MONEY_API_KEY=your-mtn-api-key
MTN_MONEY_USER_ID=your-mtn-user-id
MTN_MONEY_USER_SECRET=your-mtn-user-secret

# =============================================================================
# REDIS (Caching & Sessions)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# PUSH NOTIFICATIONS
# =============================================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@guineamanager.com

# =============================================================================
# FILE STORAGE
# =============================================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# AWS S3 (Optional)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=eu-west-1
# AWS_S3_BUCKET=guineamanager-uploads

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# BACKUP
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# =============================================================================
# MONITORING
# =============================================================================
# Sentry (Optional)
# SENTRY_DSN=your-sentry-dsn

# =============================================================================
# SEO & Analytics
# =============================================================================
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# =============================================================================
# SUPPORT
# =============================================================================
SUPPORT_EMAIL=support@guineamanager.com
SUPPORT_PHONE=+224 624 00 00 00
